# Fastfile — defines the "lanes" (automation recipes) for Android.
#
# Run a lane from the project root with:
#   bundle exec fastlane android test
#
# Docs: https://docs.fastlane.tools/actions/

# Tells Fastlane that the lanes below target the Android platform.
default_platform(:android)

platform :android do
  desc "Run the Flutter analyzer and unit tests"
  lane :test do
    # `sh` runs a shell command from inside the `android/fastlane/` directory,
    # so we `cd ../..` up to the Flutter project root before running tools.
    # We use `fvm flutter` to honor this project's pinned Flutter version.
    sh("cd ../.. && fvm flutter analyze")
    sh("cd ../.. && fvm flutter test")
  end

  desc "Build a release Android App Bundle (.aab) for the production flavor"
  lane :build do
    # Build through `flutter build` (NOT raw `gradle`) so the Dart code is
    # compiled and the flavor wiring is applied. We produce an `.aab` because
    # that's the format Google Play requires. The `production` flavor needs no
    # --dart-define-from-file (only `local` does).
    #
    # NOTE: release is still debug-signed (see android/app/build.gradle.kts),
    # so this artifact is for local verification only — not Play upload yet.
    # Output: build/app/outputs/bundle/productionRelease/app-production-release.aab
    sh("cd ../.. && fvm flutter build appbundle --flavor production")
  end
end
