# Fastfile — defines the "lanes" (automation recipes) for Android.
#
# Run a lane from the project root with:
#   bundle exec fastlane android test
#
# Docs: https://docs.fastlane.tools/actions/

# Tells Fastlane that the lanes below target the Android platform.
default_platform(:android)

platform :android do
  desc "Run the Flutter analyzer and unit tests"
  lane :test do
    # `sh` runs a shell command from inside the `android/fastlane/` directory,
    # so we `cd ../..` up to the Flutter project root before running tools.
    # We use `fvm flutter` to honor this project's pinned Flutter version.
    sh("cd ../.. && fvm flutter analyze")
    sh("cd ../.. && fvm flutter test")
  end

  desc "Build a release Android App Bundle (.aab) for the production flavor"
  lane :build do
    # Build through `flutter build` (NOT raw `gradle`) so the Dart code is
    # compiled and the flavor wiring is applied. We produce an `.aab` because
    # that's the format Google Play requires. The `production` flavor needs no
    # --dart-define-from-file (only `local` does).
    #
    # NOTE: release is still debug-signed (see android/app/build.gradle.kts),
    # so this artifact is for local verification only — not Play upload yet.
    # Output: build/app/outputs/bundle/productionRelease/app-production-release.aab
    sh("cd ../.. && fvm flutter build appbundle --flavor production")
  end

  desc "Build a release Android APK (.apk) for the production flavor"
  lane :build_apk do
    # Same `flutter build` approach as `build`, but produces an `.apk` instead
    # of an `.aab`. An APK installs directly on a device and is the format beta
    # tools like Firebase App Distribution accept (Milestone 4).
    #
    # NOTE: release is still debug-signed (see android/app/build.gradle.kts),
    # so this APK is for local install / internal testing only — not Play.
    # Output: build/app/outputs/flutter-apk/app-production-release.apk
    sh("cd ../.. && fvm flutter build apk --flavor production")
  end

  desc "Build and distribute the production APK to Firebase App Distribution"
  lane :beta_firebase do
    # Reuse the build_apk lane to produce the APK, then upload it to Firebase
    # App Distribution for the `testers` group. Authentication uses your
    # `firebase login` credentials, so no service-account key is needed locally.
    build_apk

    firebase_app_distribution(
      # Production Android app ID from android/app/src/production/google-services.json.
      app: "1:981414646881:android:4300ea58eb702e1ad1c620",
      # Path is relative to the android/ directory (where fastlane runs).
      android_artifact_path: "../build/app/outputs/flutter-apk/app-production-release.apk",
      groups: "testers",
      release_notes: "Internal test build via fastlane",
    )
  end

  desc "Build and upload the production AAB to Google Play internal testing"
  lane :beta_play do
    # Build the AAB (Play requires .aab), then upload it to the `internal`
    # test track. Auth uses the service-account key from the Appfile
    # (json_key_file). Path is relative to the android/ directory.
    #
    # Prerequisites (one-time, done in the Play Console / GCP — not by fastlane):
    #   1. App created on Play Console and at least ONE manual AAB upload.
    #   2. A service-account JSON key with release permission for this app.
    build

    upload_to_play_store(
      track: "internal",
      aab: "../build/app/outputs/bundle/productionRelease/app-production-release.aab",
    )
  end
end
