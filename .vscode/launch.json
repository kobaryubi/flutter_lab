{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter Lab Local",
            "type": "dart",
            "request": "launch",
            "preLaunchTask": "resolve-local-host",
            "args": [
                "--flavor",
                "local",
                "--dart-define-from-file=.dart_define/local.env",
                "--verbose"
            ]
        },
        {
            "name": "Flutter Lab Production",
            "type": "dart",
            "request": "launch",
            "args": [
                "--flavor",
                "production"
            ]
        },
    ]
}
