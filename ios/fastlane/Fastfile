# Fastfile — defines the "lanes" (automation recipes) for iOS.
#
# Run a lane from the project root with:
#   bundle exec fastlane ios test
#
# Docs: https://docs.fastlane.tools/actions/

# Tells Fastlane that the lanes below target the iOS platform.
default_platform(:ios)

platform :ios do
  desc "Run the Flutter analyzer and unit tests"
  lane :test do
    # `sh` runs a shell command from inside the `ios/fastlane/` directory,
    # so we `cd ../..` up to the Flutter project root before running tools.
    # We use `fvm flutter` to honor this project's pinned Flutter version.
    # This lane is platform-agnostic (same as the Android one) and needs no
    # Apple Developer account.
    sh("cd ../.. && fvm flutter analyze")
    sh("cd ../.. && fvm flutter test")
  end

  desc "Build the iOS app (no code signing) to verify it compiles"
  lane :build do
    # Build through `flutter build` (NOT raw `xcodebuild`) so the Dart code is
    # compiled and the flavor wiring (production scheme) is applied.
    #
    # `--no-codesign` skips signing entirely, so this works WITHOUT a
    # certificate / provisioning profile — it only verifies the app compiles.
    # A distributable `.ipa` (which requires signing) comes in a later
    # milestone via `flutter build ipa`.
    sh("cd ../.. && fvm flutter build ios --no-codesign --flavor production")
  end

  desc "Build a signed ad-hoc .ipa for the production flavor"
  lane :build_ipa do
    # Unlike the `build` lane (--no-codesign, compile check only), Firebase App
    # Distribution needs a SIGNED .ipa that testers can install on real devices.
    #
    # `--export-method ad-hoc` produces an artifact installable on the devices
    # listed in the ad-hoc provisioning profile (each tester's UDID must be
    # registered in the Apple Developer portal and included in the profile).
    #
    # Prerequisites (one-time, set up in Xcode or via `match` — NOT by this lane):
    #   1. Apple Developer account + distribution certificate.
    #   2. An ad-hoc provisioning profile for com.masahikokobayashi.flutterlab
    #      that lists the tester device UDIDs.
    #   3. apple_id / team_id filled in the Appfile.
    # Output: build/ios/ipa/Flutter Lab.ipa
    #
    # CocoaPods is pinned in the Gemfile, so the `pod install` that `flutter
    # build` triggers resolves to the bundled version under this `bundle exec`
    # context — no env juggling needed.
    #
    # We pass an explicit `--export-options-plist` instead of `--export-method
    # ad-hoc`. The latter makes Flutter auto-generate an ExportOptions.plist with
    # `signingStyle: automatic` (and no provisioningProfiles), which ignores our
    # manually-created ad-hoc profiles and fails with "requires a provisioning
    # profile …". The plist below pins manual signing + the exact profiles for
    # the app and the NotificationService extension. (The path is relative to the
    # project root, since we `cd ../..` first.)
    sh("cd ../.. && fvm flutter build ipa --flavor production --export-options-plist ios/ExportOptions-adhoc.plist")
  end

  desc "Build and distribute the production .ipa to Firebase App Distribution"
  lane :beta_firebase do
    # Production iOS app ID from firebase.json (Release-production mapping).
    app_id = "1:981414646881:ios:4aa48de2553c8076d1c620"

    # Same approach as the Android `beta_firebase` lane: read the build number
    # (CFBundleVersion) of the LATEST release already on Firebase App
    # Distribution, then build the next one as +1 so every upload gets a
    # strictly increasing, unique value. iOS keeps its OWN build-number history
    # on FAD, independent of Android. Auth reuses your `firebase login`
    # credentials — no service-account key needed.
    latest = firebase_app_distribution_get_latest_release(app: app_id)
    # `buildVersion` is a string ("3"); `.to_i` of a missing/nil value is 0, so
    # the first-ever release builds as 1.
    next_build_number = latest&.dig(:buildVersion).to_i + 1
    UI.message("Next build number (CFBundleVersion): #{next_build_number}")

    # Inline the build (instead of calling `build_ipa`) so we can override ONLY
    # the build number for this build — pubspec.yaml stays untouched (nothing to
    # commit). Manual signing + the ad-hoc profiles still come from
    # ExportOptions-adhoc.plist; the version NAME still comes from pubspec.yaml.
    sh("cd ../.. && fvm flutter build ipa --flavor production --export-options-plist ios/ExportOptions-adhoc.plist --build-number=#{next_build_number}")

    firebase_app_distribution(
      app: app_id,
      # `flutter build ipa` output, relative to the ios/ directory (where
      # fastlane runs). Adjust the filename if your scheme names the .ipa
      # differently.
      ipa_path: "../build/ios/ipa/Flutter Lab.ipa",
      groups: "testers",
      release_notes: "Internal test build via fastlane",
    )
  end
end
